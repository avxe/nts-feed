# NTS Feed — Environment Configuration
#
# Quick start:
#   1. Run `make quickstart` for the guided Docker setup, or copy this file to `.env`
#   2. Set a SECRET_KEY
#   3. Add optional integration keys only if you use those features
#
# Do not commit `.env`.

# ============================================================================
# REQUIRED
# ============================================================================

# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ============================================================================
# SECURITY
# ============================================================================

FLASK_ENV=production
FLASK_DEBUG=0
ENABLE_TALISMAN=true
FORCE_HTTPS=false

# ============================================================================
# DATABASE
# ============================================================================

NTS_STORAGE_ROOT=storage
DATABASE_URL=sqlite:///storage/data/nts.db

# ============================================================================
# OPTIONAL INTEGRATIONS
# ============================================================================

# Last.fm — artist metadata enrichment
LASTFM_API_KEY=
LASTFM_API_SECRET=

# Discogs — release links for tracklist items
DISCOGS_TOKEN=
DISCOGS_USER_AGENT=NTSFeed/1.0

# YouTube — inline playback for tracks
YOUTUBE_API_KEY=

# ============================================================================
# OPTIONAL APP SETTINGS
# ============================================================================

IMAGE_CACHE_DIR=storage/thumbnails
NTS_COOKIES=

# Host paths for docker-compose volume mounts.
# Leave these blank unless you want to override the repo-local defaults.
# Example:
# AUTO_ADD_DIR_HOST=/absolute/path/to/Automatically\ Add\ to\ Music.localized
# MUSIC_DIR_HOST=/absolute/path/to/Music/Compilations/NTS
AUTO_ADD_DIR_HOST=
MUSIC_DIR_HOST=
